rules_version = '2';

// ===========================================
// 🗄️ STORAGE SECURITY RULES - KID TO KID
// ===========================================
// Última atualização: Janeiro 2026

service firebase.storage {
  match /b/{bucket}/o {
    
    // ========================================
    // 📋 FUNÇÕES AUXILIARES
    // ========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.admin == true || 
              request.auth.token.email in ['info@kidtokid.pt', 'mahdisharifi4561@gmail.com']);
    }
    
    function isStaff() {
      return request.auth != null && 
             (request.auth.token.admin == true || 
              request.auth.token.moderator == true ||
              request.auth.token.email in ['info@kidtokid.pt', 'mahdisharifi4561@gmail.com']);
    }
    
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024; // 5MB máximo
    }
    
    function isValidDocument() {
      return request.resource.contentType.matches('application/pdf') &&
             request.resource.size < 10 * 1024 * 1024; // 10MB máximo
    }
    
    // ========================================
    // 🖼️ IMAGENS DE PRODUTOS
    // ========================================
    match /products/{productId}/{fileName} {
      allow read: if true;
      // Apenas staff pode gerir imagens de produtos
      allow create, update: if isStaff() && isValidImage();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 📂 IMAGENS DE CATEGORIAS
    // ========================================
    match /categories/{categoryId}/{fileName} {
      allow read: if true;
      allow create, update: if isStaff() && isValidImage();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 👤 AVATARES DE UTILIZADORES
    // ========================================
    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow create, update: if request.auth != null && 
                               request.auth.uid == userId &&
                               isValidImage() &&
                               request.resource.size < 2 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Compatibilidade com estrutura antiga
    match /avatars/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && 
        request.auth.uid == userId && 
        isValidImage();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // ========================================
    // 🏪 BANNERS / SLIDERS
    // ========================================
    match /banners/{fileName} {
      allow read: if true;
      allow create, update: if isStaff() && isValidImage();
      allow delete: if isAdmin();
    }
    
    match /sliders/{fileName} {
      allow read: if true;
      allow create, update: if isStaff() && isValidImage();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 📧 ANEXOS DE CONTACTO
    // ========================================
    match /contacts/{contactId}/{fileName} {
      allow create: if request.auth != null &&
                       (isValidImage() || isValidDocument()) &&
                       request.resource.size < 5 * 1024 * 1024;
      allow read: if isStaff();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 📦 DOCUMENTOS DE ENCOMENDAS
    // ========================================
    match /orders/{orderId}/{fileName} {
      // Apenas staff pode aceder a documentos de encomendas
      // (clientes acedem via Cloud Function que valida ownership)
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 🔒 FICHEIROS TEMPORÁRIOS
    // ========================================
    match /temp/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && 
                            request.auth.uid == userId &&
                            (isValidImage() || isValidDocument()) &&
                            request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // ========================================
    // 📊 BACKUPS
    // ========================================
    match /backups/{path=**} {
      allow read, write: if false;
    }
  }
}
