# Firebase Config — Get from Firebase Console → Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Stripe (frontend)
# Publishable key used by client-side Stripe SDK (test key for local dev)
VITE_STRIPE_PUBLISHABLE_KEY=

# App URLs (frontend)
VITE_APP_BASE_URL=http://localhost:5173

# -----------------------------------------------
# Firebase Functions env (create functions/.env)
# -----------------------------------------------
# Stripe secret key (server-only)
STRIPE_SECRET=

# Stripe webhook signing secret (server-only)
STRIPE_WEBHOOK_SECRET=

# Email sender configuration (server-only)
EMAIL_USER=
EMAIL_PASS=

# Optional operational settings
ADMIN_EMAIL=info@kidtokid.pt
NODE_ENV=development
