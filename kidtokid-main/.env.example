# Firebase Config — Get from Firebase Console → Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin emails — comma-separated list of emails that have admin access as fallback
# (Firebase custom claims are the preferred/more secure approach)
# Example: VITE_ADMIN_EMAILS=info@kidtokid.pt,admin@kidtokid.pt
VITE_ADMIN_EMAILS=
